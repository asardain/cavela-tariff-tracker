{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/asardain/cavela-tariff-tracker/schema/claim.schema.json",
  "title": "TariffClaim",
  "description": "A single factual claim about US tariff activity, extracted from a source article",
  "type": "object",
  "required": [
    "claim_id",
    "claim_text",
    "subject",
    "tariff_action",
    "source_url",
    "source_name",
    "published_date",
    "extracted_date",
    "certainty_level",
    "certainty_label",
    "certainty_rationale",
    "pedigree"
  ],
  "properties": {
    "claim_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for this claim"
    },
    "claim_text": {
      "type": "string",
      "minLength": 10,
      "maxLength": 1000,
      "description": "The factual claim in plain English, as a complete sentence"
    },
    "subject": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500,
      "description": "What product, country, or HS code is affected by this tariff action"
    },
    "tariff_action": {
      "type": "string",
      "enum": [
        "new_tariff",
        "tariff_increase",
        "tariff_removal",
        "tariff_pause",
        "investigation_opened",
        "rule_proposed",
        "other"
      ],
      "description": "The type of tariff action described in this claim"
    },
    "effective_date": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        {
          "type": "null"
        }
      ],
      "description": "ISO date (YYYY-MM-DD) when the tariff action takes effect, or null if not stated"
    },
    "source_url": {
      "type": "string",
      "format": "uri",
      "description": "URL of the source article"
    },
    "source_name": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable name of the source (e.g. 'Federal Register', 'Reuters')"
    },
    "published_date": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 datetime of when the source article was published"
    },
    "extracted_date": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 datetime of when this claim was extracted"
    },
    "certainty_level": {
      "type": "integer",
      "minimum": 1,
      "maximum": 7,
      "description": "Reliability level 1-7 per the Cavela ontology"
    },
    "certainty_label": {
      "type": "string",
      "enum": [
        "SPECULATION",
        "REPORTED",
        "PROPOSED",
        "ANNOUNCED",
        "EXECUTIVE_ORDER",
        "RULE_PUBLISHED",
        "LAW"
      ],
      "description": "Human-readable label for the certainty level"
    },
    "certainty_rationale": {
      "type": "string",
      "minLength": 10,
      "maxLength": 500,
      "description": "One sentence explaining why this certainty level was assigned"
    },
    "pedigree": {
      "type": "object",
      "required": [
        "source_name",
        "source_category",
        "source_url",
        "published_date",
        "extracted_date",
        "certainty_level"
      ],
      "properties": {
        "source_name": {
          "type": "string"
        },
        "source_category": {
          "type": "string",
          "enum": [
            "official_us_gov",
            "international_body",
            "news_wire",
            "financial_press"
          ]
        },
        "source_url": {
          "type": "string",
          "format": "uri"
        },
        "published_date": {
          "type": "string",
          "format": "date-time"
        },
        "extracted_date": {
          "type": "string",
          "format": "date-time"
        },
        "certainty_level": {
          "type": "integer",
          "minimum": 1,
          "maximum": 7
        }
      },
      "description": "Full provenance chain for this claim"
    }
  },
  "additionalProperties": false
}
